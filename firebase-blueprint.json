{
  "entities": {
    "User": {
      "title": "User",
      "description": "Application user profile",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "pharmacy", "client"] },
        "cep": { "type": "string" },
        "street": { "type": "string" },
        "number": { "type": "string" },
        "neighborhood": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role", "created_at"]
    },
    "Pharmacy": {
      "title": "Pharmacy",
      "description": "Pharmacy profile details",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "whatsapp": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "website": { "type": "string" },
        "street": { "type": "string" },
        "number": { "type": "string" },
        "neighborhood": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "zip": { "type": "string" },
        "cep": { "type": "string" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "is_active": { "type": "number" },
        "subscription_active": { "type": "boolean" },
        "whatsapp_clicks": { "type": "number" },
        "map_clicks": { "type": "number" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "name", "city", "state", "is_active", "created_at"]
    },
    "Subscription": {
      "title": "Subscription",
      "description": "Pharmacy subscription status",
      "type": "object",
      "properties": {
        "pharmacy_id": { "type": "string" },
        "payer_email": { "type": "string", "format": "email" },
        "status": { "type": "string", "enum": ["pending", "authorized", "active", "cancelled", "expired"] },
        "plan_type": { "type": "string", "enum": ["monthly", "annual"] },
        "amount": { "type": "number" },
        "payment_method": { "type": "string" },
        "external_reference": { "type": "string" },
        "next_billing_date": { "type": "string", "format": "date-time" },
        "expires_at": { "type": "string", "format": "date-time" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "required": ["pharmacy_id", "status", "created_at"]
    },
    "Highlight": {
      "title": "Highlight",
      "description": "Exclusive highlight for a pharmacy in a city",
      "type": "object",
      "properties": {
        "pharmacy_id": { "type": "string" },
        "type": { "type": "string", "enum": ["day"] },
        "date_start": { "type": "string", "format": "date-time" },
        "date_end": { "type": "string", "format": "date-time" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "required": ["pharmacy_id", "type", "date_start", "date_end", "city", "state", "created_at"]
    },
    "Payment": {
      "title": "Payment",
      "description": "Payment records for subscriptions",
      "type": "object",
      "properties": {
        "pharmacy_id": { "type": "string" },
        "amount": { "type": "number" },
        "method": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "mp_payment_id": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "required": ["pharmacy_id", "amount", "status", "created_at"]
    },
    "Shift": {
      "title": "Shift",
      "description": "On-call shift for a pharmacy",
      "type": "object",
      "properties": {
        "pharmacy_id": { "type": "string" },
        "date": { "type": "string" },
        "start_time": { "type": "string" },
        "end_time": { "type": "string" },
        "is_24h": { "type": "number" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "required": ["pharmacy_id", "date", "start_time", "end_time", "is_24h", "created_at"]
    },
    "Click": {
      "title": "Click",
      "description": "Metric tracking for pharmacy interactions",
      "type": "object",
      "properties": {
        "pharmacy_id": { "type": "string" },
        "type": { "type": "string", "enum": ["whatsapp", "map"] },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "required": ["pharmacy_id", "type", "created_at"]
    },
    "Config": {
      "title": "Config",
      "description": "System configuration documents",
      "type": "object",
      "properties": {
        "public_key": { "type": "string" },
        "access_token": { "type": "string" },
        "monthly": { "type": "object" },
        "annual": { "type": "object" },
        "updated_at": { "type": "string", "format": "date-time" }
      }
    },
    "PricingBlock": {
      "title": "PricingBlock",
      "description": "Benefits/Feature blocks on the pricing page",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "icon": { "type": "string" },
        "color": { "type": "string" },
        "is_active": { "type": "boolean" },
        "order": { "type": "number" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "is_active", "order"]
    },
    "AuditLog": {
      "title": "AuditLog",
      "description": "Trail of manual administrative actions",
      "type": "object",
      "properties": {
        "admin_id": { "type": "string" },
        "resource_type": { "type": "string" },
        "resource_id": { "type": "string" },
        "action": { "type": "string" },
        "details": { "type": "object" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["admin_id", "resource_type", "resource_id", "action", "timestamp"]
    }
  },
  "firestore": {
    "/audit_logs/{logId}": {
      "schema": "AuditLog",
      "description": "Audit trails for administrative changes"
    },
    "/config/{configId}": {
      "schema": "Config",
      "description": "System configuration flags and API keys"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/pharmacies/{pharmacyId}": {
      "schema": "Pharmacy",
      "description": "Pharmacy profile documents"
    },
    "/subscriptions/{subscriptionId}": {
      "schema": "Subscription",
      "description": "Subscription records"
    },
    "/highlights/{highlightId}": {
      "schema": "Highlight",
      "description": "Exclusive highlights"
    },
    "/payments/{paymentId}": {
      "schema": "Payment",
      "description": "Payment records"
    },
    "/shifts/{shiftId}": {
      "schema": "Shift",
      "description": "On-call shifts"
    },
    "/clicks/{clickId}": {
      "schema": "Click",
      "description": "Interaction metrics"
    },
    "/pricing_blocks/{blockId}": {
      "schema": "PricingBlock",
      "description": "Individual feature blocks on the pricing page"
    }
  }
}
